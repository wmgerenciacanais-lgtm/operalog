# OperaLog — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# Banco de dados PostgreSQL (Railway fornece automaticamente)
DATABASE_URL=postgresql://usuario:senha@host:5432/operalog

# Chave secreta JWT (gere uma chave aleatória forte)
JWT_SECRET=operalog_chave_secreta_troque_isso_em_producao_2025

# Ambiente
NODE_ENV=production

# Porta (Railway define automaticamente)
PORT=3000
